# --- HTTP server ---
PORT=8090

# --- SQLite (created automatically) ---
DB_PATH=data/activity.db

# --- GitHub (uses local `gh` CLI — no PAT needed) ---
# Make sure `gh auth status` shows you logged in.
# Override the username if `gh api user` doesn't return who you want:
# GITHUB_USER=
GITHUB_LOOKBACK_DAYS=30
# GH_BINARY=gh

# --- Claude Code (local sessions) ---
# Defaults to ~/.claude/projects
# CLAUDE_PROJECTS_DIR=
# CLAUDE_BINARY=claude

# --- Gmail / Jira (optional) ---
# 1. Create a Google Cloud project (no billing needed; Gmail API is in the Always Free tier)
# 2. Enable Gmail API
# 3. Create an OAuth client (Web application). Add redirect URI: http://localhost:8090/oauth/gmail/callback
# 4. Download the credentials JSON and save it as data/gmail_credentials.json
# 5. Start the server, click "authorize →" in the footer
GMAIL_CREDENTIALS_JSON=data/gmail_credentials.json
GMAIL_TOKEN_JSON=data/gmail_token.json
OAUTH_REDIRECT_URL=http://localhost:8090/oauth/gmail/callback
# Substring of the Jira notification "From" address (default: atlassian.net)
JIRA_SENDER_FILTER=atlassian.net
